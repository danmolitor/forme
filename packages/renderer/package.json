{
  "name": "@formepdf/renderer",
  "version": "0.7.1",
  "description": "File-to-PDF rendering pipeline for Forme — bundles TSX, resolves assets, renders via WASM",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    },
    "./preview": "./dist/preview/index.html"
  },
  "scripts": {
    "build": "tsc && rm -rf dist/preview && cp -r src/preview dist/preview",
    "test": "vitest run"
  },
  "dependencies": {
    "@formepdf/core": "0.7.0",
    "@formepdf/react": "0.7.0",
    "esbuild": "^0.24.0"
  },
  "peerDependencies": {
    "react": "^18 || ^19"
  },
  "devDependencies": {
    "@types/node": "^22.0.0",
    "@types/react": "^19.0.0",
    "react": "^19.0.0",
    "typescript": "^5.7.0",
    "vitest": "^3.0.0"
  },
  "files": [
    "dist"
  ],
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/formepdf/forme",
    "directory": "packages/renderer"
  }
}
